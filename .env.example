# BuildUp Games — environment variables
# Copy to .env.local and fill in real values.

# Public site URL (used for OG tags, canonical, sitemap)
NEXT_PUBLIC_SITE_URL=https://buildupgames.com

# Plausible analytics — set to your registered domain (e.g. buildupgames.com).
# Leave empty to disable.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Resend — contact form email delivery.
# Get an API key at https://resend.com
RESEND_API_KEY=

# Email configuration
CONTACT_TO_EMAIL=contact@buildupgames.org
CONTACT_FROM_EMAIL="BuildUp Games <noreply@buildupgames.com>"

# Discord server ID (used by the Team section's Discord popover widget).
# To get it: Discord server → right-click the server icon → "Copy Server ID"
# (requires Developer Mode enabled in User Settings → Advanced).
# Also enable the Widget in Server Settings → Widget so the popover shows live members.
NEXT_PUBLIC_DISCORD_SERVER_ID=
